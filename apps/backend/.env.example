# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apply_flow"

# Frontend origin allowed by CORS
FRONTEND_URL="http://localhost:3000"

# JWT secret for bearer token signing
JWT_SECRET="change_me_in_production"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# SMTP configuration for verification email sending
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="YOUR_GMAIL_ADDRESS@gmail.com"
SMTP_PASS="YOUR_16_CHAR_GMAIL_APP_PASSWORD"
SMTP_FROM="YOUR_GMAIL_ADDRESS@gmail.com"

# Gemini API Key (used by /api/jobs/:id/analyze)
GEMINI_API_KEY=""
