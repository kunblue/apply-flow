# Docker Compose 会读取这个变量并注入 backend 容器
GEMINI_API_KEY=

# SMTP configuration for verification email sending (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=YOUR_GMAIL_ADDRESS@gmail.com
SMTP_PASS=YOUR_16_CHAR_GMAIL_APP_PASSWORD
SMTP_FROM=YOUR_GMAIL_ADDRESS@gmail.com
